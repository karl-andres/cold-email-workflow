# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cold_email
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/cold_email

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "anthropic" | "openai" | "ollama"
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...
# claude-sonnet-4-5 for writing/eval, claude-haiku-4-5-20251001 for routing
WRITER_MODEL=claude-sonnet-4-5
ROUTER_MODEL=claude-haiku-4-5-20251001

OPENAI_API_KEY=sk-...
OPENAI_WRITER_MODEL=gpt-4o
OPENAI_ROUTER_MODEL=gpt-4o-mini

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_WRITER_MODEL=llama3.1:70b
OLLAMA_ROUTER_MODEL=llama3.1:8b

# Embeddings
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# ── External APIs ─────────────────────────────────────────────────────────────
PROXYCURL_API_KEY=
FIRECRAWL_API_KEY=

# ── LangSmith ────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=cold-email-workflow

# ── Qualification Thresholds ─────────────────────────────────────────────────
MIN_COMPANY_SIZE=2
MAX_COMPANY_SIZE=100
ALLOWED_STAGES=seed,pre_seed,series_a

# ── Safety ────────────────────────────────────────────────────────────────────
MAX_DRAFT_ATTEMPTS=3
MAX_TOOL_RETRIES=4

# ── User ──────────────────────────────────────────────────────────────────────
USER_ID=karl
